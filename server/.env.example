# ════════════════════════════════════════════════════════════
#  VISION CORE SERVER — Variáveis de Ambiente
#  cp .env.example .env  →  edite com suas chaves
# ════════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────────────────────
PORT=8787
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8787

# ── Banco de dados ────────────────────────────────────────────────────────
DB_PATH=.vault/vision_core.db
DB_VERBOSE=false

# ── AI Providers (ordem de prioridade = fallback automático) ──────────────
AI_PROVIDER_ORDER=groq,openrouter,gemini,anthropic,ollama

GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o-mini

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=mistral

# ── Hermes ────────────────────────────────────────────────────────────────
HERMES_TIMEOUT_MS=20000
HERMES_MAX_TOKENS=1024
CONFIDENCE_THRESHOLD=60

# ── Pipeline ──────────────────────────────────────────────────────────────
AUTO_PR=true
MISSION_RATE_LIMIT=10

# ── GitHub ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=seu-usuario
GITHUB_REPO=seu-repo
GITHUB_BASE_BRANCH=main

# ── Arquitetura Híbrida GitHub + Gitness ─────────────────────────────────
# Opções de modo:
#   github_only   = apenas GitHub (padrão, sem Gitness)
#   hybrid        = GitHub = produção | Gitness = laboratório interno
#   gitness_only  = apenas Gitness (para ambientes offline)
HYBRID_GIT_MODE=github_only

# ── Gitness / Harness Open Source ─────────────────────────────────────────
# Para subir Gitness local:
#   docker run -d --name gitness -p 3000:3000 -v gitness-data:/data harness/gitness
# Depois: http://localhost:3000 → criar conta → importar repo do GitHub

GITNESS_HOST=localhost
GITNESS_PORT=3000
GITNESS_PROTOCOL=http
GITNESS_TOKEN=...              # User Settings → Tokens → Generate Token
GITNESS_ACCOUNT=seu-usuario    # seu login no Gitness
GITNESS_REPO=vision-core       # nome do repositório no Gitness
GITNESS_SPACE=default          # space/org do Gitness (padrão: default)
GITNESS_BASE_BRANCH=main

# Validação do pipeline Gitness (false = apenas informativo, não bloqueia)
GITNESS_VALIDATION_REQUIRED=false

# Tempo máximo aguardando pipeline Gitness (0 = não aguarda)
GITNESS_WAIT_PIPELINE_MS=0

# ── TechNetGame (projeto monitorado) ────────────────────────────────────
TECHNETGAME_PATH=C:/Users/imadechumbo/Desktop/technetgamev2-main/backend
TECHNETGAME_HEALTH_URL=https://api.technetgame.com.br/api/health
