{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VisionCore Mission Result",
  "description": "Contrato de saída JSON puro do Go Safe Core V14.4 — evidence_receipt real obrigatório",
  "type": "object",
  "required": [
    "ok",
    "version",
    "mission_id",
    "engine",
    "status",
    "pass_gold",
    "promotion_allowed",
    "rollback_ready",
    "summary",
    "steps"
  ],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "version": {
      "type": "string",
      "const": "5.0.0-go-safe-core"
    },
    "mission_id": {
      "type": "string",
      "pattern": "^mission_[a-f0-9]+$",
      "description": "Stable mission identifier generated by Go Core only"
    },
    "engine": {
      "type": "string",
      "const": "go-safe-core"
    },
    "status": {
      "type": "string",
      "enum": [
        "GOLD",
        "FAIL"
      ]
    },
    "pass_gold": {
      "type": "boolean"
    },
    "promotion_allowed": {
      "type": "boolean"
    },
    "rollback_ready": {
      "type": "boolean"
    },
    "summary": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "step_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "step",
          "ok"
        ],
        "properties": {
          "step": {
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      }
    },
    "gates": {
      "$ref": "#/definitions/Gates"
    },
    "failed_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "error": {
      "type": "string"
    },
    "backend_stub": {
      "type": "boolean",
      "description": "Always false when Go Core executes real mission. True only in backend error paths.",
      "const": false
    },
    "evidence_source": {
      "type": "string",
      "description": "Origin of evidence_receipt. Must always be go-core when generated by Go Core.",
      "const": "go-core"
    },
    "evidence_receipt": {
      "type": "object",
      "description": "Real traceable evidence of Go Core mission execution. Backend must never fabricate this.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique receipt ID generated by Go Core"
        },
        "mission_id": {
          "type": "string",
          "description": "Must match the top-level mission_id — proves receipt belongs to this mission"
        },
        "snapshot_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "gates_hash": {
          "type": "string",
          "description": "SHA-256 hash of evaluated gates — non-empty proves real gate evaluation"
        },
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "result": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "pass_gold": {
          "type": "boolean",
          "description": "Must match top-level pass_gold — any mismatch indicates tampering"
        },
        "failed_gates": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Gates that failed during this mission execution"
        },
        "source": {
          "type": "string",
          "const": "go-core",
          "description": "Immutable origin marker. Backend must never create evidence with source=go-core."
        }
      },
      "required": [
        "id",
        "mission_id",
        "issued_at",
        "result",
        "source"
      ]
    }
  },
  "definitions": {
    "Gates": {
      "type": "object",
      "required": [
        "scanner_ok",
        "fileops_ok",
        "patcher_ok",
        "validator_ok",
        "rollback_ready",
        "security_ok",
        "legacy_safe"
      ],
      "properties": {
        "scanner_ok": {
          "type": "boolean"
        },
        "fileops_ok": {
          "type": "boolean"
        },
        "patcher_ok": {
          "type": "boolean"
        },
        "validator_ok": {
          "type": "boolean"
        },
        "rollback_ready": {
          "type": "boolean"
        },
        "security_ok": {
          "type": "boolean"
        },
        "legacy_safe": {
          "type": "boolean"
        }
      }
    }
  },
  "additionalProperties": false
}
