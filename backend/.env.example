# Vision Core V4.1 - Variaveis de Ambiente Obrigatorias

# Auth/session - OBRIGATORIO em producao
# Geracao sugerida: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=gere_com_node_crypto_randomBytes_32_toString_hex

# Legado: nao e usado por backend/server.js para assinar sessao.
# Mantido so para compatibilidade com scripts antigos que leem o exemplo.
JWT_SECRET=

# Stripe - obrigatorio para billing real
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# GitHub CI - opcional
GITHUB_TOKEN=ghp_...
GITHUB_REPO=Imadechumbo/vision-core-master

# Database
DB_PATH=./data/db.json

# Porta
PORT=3000

# EB / AWS
NODE_ENV=production
